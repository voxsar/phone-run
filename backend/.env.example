APP_NAME="Runner Occupy"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://runneroccupy.dev.artslabcreatives.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=phone_run
DB_USERNAME=phone_run
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=database
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/api/auth/google/callback

# Facebook OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=${APP_URL}/api/auth/facebook/callback

# JWT
JWT_SECRET=
JWT_TTL=43200

FILAMENT_ADMIN_EMAIL=admin@runneroccupy.dev.artslabcreatives.com
FILAMENT_ADMIN_PASSWORD=changeme
